{
  "rewrites": [
    { "source": "/ai", "destination": "https://oorjakull-six.vercel.app/" },
    { "source": "/ai/:path*", "destination": "https://oorjakull-six.vercel.app/:path*" },
    { "source": "/assets/:path*", "destination": "https://oorjakull-six.vercel.app/assets/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}